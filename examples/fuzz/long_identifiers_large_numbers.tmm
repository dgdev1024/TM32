; Edge case: Very long symbol names and large numbers
.let very_long_symbol_name_that_tests_maximum_identifier_length_abcdefghijklmnopqrstuvwxyz = 0x7FFFFFFF
.let another_extremely_long_variable_name_to_test_symbol_table_limits_123456789 = 0xFFFFFFFF
.let super_mega_ultra_long_identifier_name_for_stress_testing_purposes_only = 0x80000000

.for very_long_symbol_name_that_tests_maximum_identifier_length_abcdefghijklmnopqrstuvwxyz 1 3
  ld a, very_long_symbol_name_that_tests_maximum_identifier_length_abcdefghijklmnopqrstuvwxyz
  .assert another_extremely_long_variable_name_to_test_symbol_table_limits_123456789
.endfor

; Test extremely large numbers
.let huge_number = 0xFFFFFFFFFFFFFFFF
.let decimal_huge = 4294967295
.let binary_huge = 0b11111111111111111111111111111111
.let octal_huge = 0o37777777777

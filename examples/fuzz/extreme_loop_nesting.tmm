; Edge case: Extreme loop nesting
.for i 1 3
  .for j 1 2
    .while i < 5
      .repeat 2
        .for k 1 2
          mov r0, i
          mov r1, j
          mov r2, k
          .if k == 2
            .break
          .endif
        .endfor
      .endr
      .let i = i + 1
    .endwhile
  .endfor
.endfor

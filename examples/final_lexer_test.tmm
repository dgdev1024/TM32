; Final Comprehensive Lexer Test
; Testing all operator types including three-character assignment operators
;
; Note: This file is only meant to be lexed!

.data
value: .dd 100

.text
test_operators:
    ; Basic arithmetic
    ld a, value
    
    ; Two-character operators
    ld b, value << 2
    ld c, value >> 1
    ld d, value ** 2
    
    ; Three-character assignment operators
    value += 10      ; Addition assignment
    value -= 5       ; Subtraction assignment  
    value *= 2       ; Multiplication assignment
    value <<= 1      ; Left shift assignment
    value >>= 1      ; Right shift assignment
    value **= 2      ; Exponent assignment
    
    ; Comparison and logical
    cmp a, (value == 100)
    jmp zs, end
    
    ; Macro tokens
    @? = @# + @* - @-
    
end:
    halt

; Comprehensive Lexer Test
; This file tests various token types and edge cases

; Constants and variables
.const MAX_SIZE = 1024
.let counter = 0

; Numbers in different bases
.data
hex_values: .dd 0x12345678, 0xABCDEF
binary_values: .db 0b1010, 0b1111
octal_values: .dw 0o777, 0o123
decimal_values: .dd 42, 0, 999
fixed_point: .dd 3.14159, -2.5

; String and character literals
msg: .asciz "Hello, World!\n"
single_char: .db 'A', '\n', '\0'
graphics: .db `01234567`

; Labels and instructions
.text
start:
    ; Basic instructions with different operands
    ld   a, MAX_SIZE
    mv   b, [counter + 1]
    add  a, (MAX_SIZE * 2)
    
    ; Macro parameters and special tokens
    @? = @# + @*
    
    ; Complex expressions
    ld   c, (high(0x12345678) << 8) | low(0x12345678)
    
    ; Conditional and comparison
    cmp  a, MAX_SIZE
    jmp  zs, end
    
    ; Assignment operators
    counter += 1
    counter *= 2
    counter <<= 1
    
end:
    halt

; Macro definition
.macro TEST_MACRO
    push @1
    ld   a, @2
    call @0_handler
    pop  @1
.endmacro

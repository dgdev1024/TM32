; Comprehensive Preprocessor Test
; This file demonstrates the underlying preprocessor functionality

; Test symbol table functionality with constants
.const BUFFER_SIZE = 1024
.const MAX_ITERATIONS = 100
.const DEBUG_MODE = 1

; Test variable definitions  
.let counter = 0
.let current_pos = BUFFER_SIZE

; Test include stack (will be processed by preprocessor)
; .include "common_macros.inc"

; Test conditional compilation preparation
.if DEBUG_MODE
    ; Debug-specific code
    .const LOG_LEVEL = 3
.else
    ; Release-specific code  
    .const LOG_LEVEL = 1
.endif

; Test macro definition preparation
.macro SAVE_REGISTERS
    push a
    push b
    push c
    push d
.endmacro

.macro RESTORE_REGISTERS
    pop d
    pop c  
    pop b
    pop a
.endmacro

; Test macro invocation with parameters
.macro ADD_IMMEDIATE reg, value
    ld a, reg
    add a, value
    ld reg, a
.endmacro

.text
start:
    ; Use defined symbols
    ld a, BUFFER_SIZE
    ld b, counter
    
    ; Use macro (will be expanded by preprocessor)
    SAVE_REGISTERS
    ADD_IMMEDIATE b, 10
    RESTORE_REGISTERS
    
    halt
mask = 0xFF & 0x0F
shifted = 1 << 8

; Test macro-like tokens (these are tokenized but not yet processed)
@0, @1, @2              ; Macro parameter tokens
@#, @*, @-              ; Special macro tokens
@?                      ; Unique name token

; Test file demonstrating TM32 Assembler Preprocessor functionality
; This file shows the basic preprocessing capabilities that have been implemented

; The following would be handled by the preprocessor when directive processing is added:
; .const MAX_VALUE = 100
; .let counter = 0
; .define SQUARE(x) ((x) * (x))

; For now, test basic symbol substitution manually
TEST_CONSTANT = 42
variable_name = 16

; Test various token types
add a, TEST_CONSTANT    ; Should substitute TEST_CONSTANT with 42
mov bw, variable_name   ; Should substitute variable_name with 16
ld ch, 0xFF             ; Regular hex literal
sub dl, 0b1010          ; Binary literal

; Test operators and expressions
result = TEST_CONSTANT + variable_name
mask = 0xFF & 0x0F
shifted = 1 << 8

; Test macro-like tokens (these are tokenized but not yet processed)
@0, @1, @2              ; Macro parameter tokens
@#, @*, @-              ; Special macro tokens
@?                      ; Unique name token
